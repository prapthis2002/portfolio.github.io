---
// You can import a different image for the about section if available
import profileImg from '../assets/IMG_9708.JPG';
---

<section class="about" id="about">
  <div class="about-container">
    <h2 class="about-title">ABOUT ME</h2>
    
    <div class="about-content">
      <div class="about-left">
        <div class="about-section">
          <h3 class="section-label">WHAT I DO</h3>
          <p class="section-text">I enjoy turning ideas into visuals that not only look good but also make sense.</p>
        </div>

        <div class="about-section">
          <h3 class="section-label">MY BACKGROUND</h3>
          <p class="section-text">Started as a logistics intern but ended up designing social media posts. That's where my first real design journey kicked off.</p>
        </div>

        <div class="about-section">
          <h3 class="section-label">MY APPROACH</h3>
          <p class="section-text">My process is simple:</p>
          <ul class="approach-list">
            <li>Understand the idea</li>
            <li>Translate it into visuals</li>
            <li>Remove anything that doesn't belong</li>
          </ul>
          <p class="section-text">I believe good design doesn't need long explanations. If it works, you feel it. If it doesn't... I redesign it.</p>
        </div>

        <div class="about-section">
          <h3 class="section-label">CAREER</h3>
          <div class="career-item">
            <span class="career-date">[2023 - Present]</span>
            <span class="career-role">Freelance at J.V. Springs</span>
          </div>
          <div class="career-item">
            <span class="career-date">[Feb 2024 - Jul 2024]</span>
            <span class="career-role">Junior Procurement at Primacy Industries Pvt. Ltd.</span>
          </div>
          <div class="career-item">
            <span class="career-date">[Jul 2024 - Present]</span>
            <span class="career-role">Visual Designer at MRR Technology Solutions Pvt. Ltd.</span>
          </div>
        </div>

        <div class="about-section">
          <h3 class="section-label">TOOLS & TECHNOLOGIES</h3>
          <div class="tags">
            <span class="tag">Figma</span>
            <span class="tag">Indesign</span>
            <span class="tag">Illustrator</span>
            <span class="tag">Photoshop</span>
            <span class="tag">Copout</span>
            <span class="tag">Canva</span>
          </div>
        </div>

        <div class="about-section">
          <h3 class="section-label">TOOLS & TECHNOLOGIES</h3>
          <div class="tags">
            <span class="tag">UI/UX Design</span>
            <span class="tag">Visual Design</span>
            <span class="tag">Prototyping</span>
            <span class="tag">Creative thinking</span>
            <span class="tag">Copout</span>
          </div>
        </div>
      </div>

      <div class="about-right">
        <div class="photo-container">
          <img src={profileImg.src} alt="Prapthi S" class="profile-photo" />
        </div>
        <div class="cta-buttons">
          <a href="#contact" class="cta-btn">CONTACT ME</a>
          <a href="#work" class="cta-btn">FEATURED WORK</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background-color: #1a1a1a;
    color: var(--color-white);
    padding: 5rem 3rem;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  .about-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .about-title {
    font-family: var(--font-syne);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin: 0 0 4rem 0;
    letter-spacing: 2px;
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .about-left {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .about-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-label {
    font-family: var(--font-syne);
    font-size: 0.75rem;
    font-weight: 400;
    color: #666;
    letter-spacing: 2px;
    margin: 0;
    text-transform: uppercase;
  }

  .section-text {
    font-family: var(--font-syne);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
    color: var(--color-white);
  }

  .approach-list {
    margin: 0.5rem 0;
    padding-left: 1.5rem;
    font-family: var(--font-syne);
    font-size: 1rem;
    line-height: 1.8;
  }

  .approach-list li {
    color: var(--color-white);
  }

  .career-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1rem;
  }

  .career-date {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    color: var(--color-red);
    font-weight: 700;
  }

  .career-role {
    font-family: var(--font-syne);
    font-size: 1rem;
    color: var(--color-white);
    font-weight: 400;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 400;
    background-color: #2a2a2a;
    color: var(--color-white);
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    border: 1px solid #3a3a3a;
  }

  .about-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .photo-container {
    width: 100%;
    max-width: 400px;
    border: 4px solid var(--color-red);
    overflow: hidden;
  }

  .profile-photo {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
  }

  .cta-buttons {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .cta-btn {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 700;
    background-color: var(--color-red);
    color: var(--color-white);
    padding: 0.9rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }

  .cta-btn:hover {
    background-color: #cc0004;
    transform: translateY(-2px);
  }

  @media (max-width: 1024px) {
    .about-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about-right {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .about {
      padding: 3rem 2rem;
    }

    .about-title {
      margin-bottom: 2rem;
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta-btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
