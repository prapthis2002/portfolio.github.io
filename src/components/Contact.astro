---
const { currentPage = 'contact' } = Astro.props;
---

<section class="contact" id="contact">
  <div class="contact-container">
    <div class="contact-content">
      <p class="get-in-touch">GET IN TOUCH</p>
      
      <h2 class="contact-title">
        <span class="red">Let's create</span>
        <span class="gray">something great</span>
      </h2>

      <div class="contact-layout">
        <div class="contact-info">
          <div class="info-section">
            <h3 class="info-label">EMAIL</h3>
            <a href="mailto:prapthi.s2002@gmail.com" class="info-value">prapthi.s2002@gmail.com</a>
          </div>

          <div class="info-section">
            <h3 class="info-label">LOCATION</h3>
            <p class="info-value">Available Worldwide</p>
          </div>

          <div class="info-section">
            <h3 class="info-label">SOCIAL</h3>
            <div class="social-links">
              <a href="#" class="social-btn" target="_blank" rel="noopener noreferrer">Behance</a>
              <a href="#" class="social-btn" target="_blank" rel="noopener noreferrer">Instagram</a>
              <a href="#" class="social-btn" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>
          </div>
        </div>

        <div class="contact-form-wrapper">
          <form class="contact-form">
            <input 
              type="text" 
              name="name" 
              placeholder="Your Name" 
              required
              class="form-input"
            />
            
            <input 
              type="email" 
              name="email" 
              placeholder="Your Email" 
              required
              class="form-input"
            />
            
            <textarea 
              name="message" 
              placeholder="Tell me about your project..." 
              required
              class="form-textarea"
            ></textarea>
            
            <button type="submit" class="submit-btn">SEND MESSAGE</button>
          </form>
        </div>
      </div>
    </div>

    <footer class="contact-footer">
      <p class="copyright">© 2024 Prapthi.s. All rights reserved.</p>
      <p class="tagline">Designed with passion</p>
    </footer>
  </div>
</section>

<style>
  .contact {
    background-color: #0a0a0a;
    color: var(--color-white);
    min-height: 100vh;
    padding: 5rem 3rem 3rem;
    display: flex;
    flex-direction: column;
  }

  .contact-container {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .contact-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 0;
  }

  .get-in-touch {
    font-family: var(--font-syne);
    font-size: 0.75rem;
    font-weight: 400;
    color: #666;
    letter-spacing: 3px;
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
  }

  .contact-title {
    font-family: var(--font-syne);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    margin: 0 0 4rem 0;
    line-height: 1.2;
    letter-spacing: 2px;
  }

  .contact-title .red {
    display: block;
    color: var(--color-red);
  }

  .contact-title .gray {
    display: block;
    color: #888;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    background: rgba(20, 20, 20, 0.5);
    border: 1px solid #2a2a2a;
    border-radius: 20px;
    padding: 3.5rem;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .info-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .info-label {
    font-family: var(--font-syne);
    font-size: 0.75rem;
    font-weight: 400;
    color: #666;
    letter-spacing: 2px;
    margin: 0;
    text-transform: uppercase;
  }

  .info-value {
    font-family: var(--font-syne);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-white);
    margin: 0;
    text-decoration: none;
  }

  .info-value:hover {
    color: var(--color-red);
  }

  .social-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .social-btn {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 400;
    background-color: #1a1a1a;
    color: var(--color-white);
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    border: 1px solid #3a3a3a;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .social-btn:hover {
    border-color: var(--color-red);
    color: var(--color-red);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-input,
  .form-textarea {
    font-family: var(--font-syne);
    font-size: 1rem;
    background: transparent;
    border: none;
    border-bottom: 1px solid #3a3a3a;
    color: var(--color-white);
    padding: 1rem 0;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: #666;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-bottom-color: var(--color-red);
  }

  .form-textarea {
    min-height: 120px;
    resize: vertical;
    font-family: var(--font-syne);
  }

  .submit-btn {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 700;
    background-color: var(--color-white);
    color: var(--color-black);
    padding: 1rem 2.5rem;
    border-radius: 50px;
    border: none;
    letter-spacing: 1px;
    cursor: pointer;
    align-self: flex-start;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }

  .submit-btn:hover {
    background-color: var(--color-red);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  .contact-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 3rem;
    margin-top: auto;
  }

  .copyright,
  .tagline {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 400;
    color: #666;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .contact {
      padding: 5rem 2rem 2rem;
    }

    .contact-layout {
      padding: 2rem;
    }

    .contact-footer {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    .submit-btn {
      width: 100%;
    }
  }
</style>
