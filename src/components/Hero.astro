---
import { getImage } from 'astro:assets';
import bgImage from '../assets/IMG_4534.JPG';

const { currentPage = 'home' } = Astro.props;
const optimizedBg = await getImage({ src: bgImage, width: 1920, format: 'webp', quality: 80 });
---

<section class="hero" id="home" style={`background-image: url(${optimizedBg.src})`}>
  <div class="hero-content">
    <header class="header" id="main-header">
      <div class="logo">PRAPTHI.S</div>
      <nav class="nav">
        <a href="#home" class="nav-link" data-section="home" data-cursor-hover>HOME</a>
        <a href="#about" class="nav-link" data-section="about" data-cursor-hover>ABOUT</a>
        <a href="#work" class="nav-link" data-section="work" data-cursor-hover>WORK</a>
        <a href="#contact" class="nav-link" data-section="contact" data-cursor-hover>CONTACT</a>
      </nav>
    </header>

    <div class="hero-text">
      <h1>
        <span class="hi line-in">Hi, I'm</span>
        <span class="name line-in line-in-delay-1">PRAPTHI. S</span>
      </h1>
      <p class="tagline line-in line-in-delay-2">
        <span class="red">Creating digital</span> <span class="gray">experiences</span>
      </p>
    </div>

    <div class="scroll-cue">
      <span class="scroll-cue-line"></span>
      <span class="scroll-cue-text">SCROLL</span>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');
    const header = document.getElementById('main-header');
    const heroSection = document.getElementById('home');
    
    // Handle scroll for blur effect
    const handleScroll = () => {
      if (heroSection) {
        const heroHeight = heroSection.offsetHeight;
        // Add blur when scrolled past 50% of hero section
        if (window.scrollY > heroHeight * 0.5) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      }
    };
    
    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Initial check
    
    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -60% 0px',
      threshold: 0
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const sectionId = entry.target.getAttribute('id');
          
          navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('data-section') === sectionId) {
              link.classList.add('active');
            }
          });
        }
      });
    }, observerOptions);
    
    sections.forEach(section => observer.observe(section));
    
    // Smooth scroll
    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href').substring(1);
        const targetSection = document.getElementById(targetId);
        if (targetSection) {
          targetSection.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  });
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: scroll;
    overflow: hidden;
    min-height: 100vh;
    max-height: 100vh;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.2);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 3rem;
    background: transparent;
    backdrop-filter: none;
    z-index: 1000;
    transition: background 0.3s ease, backdrop-filter 0.3s ease;
  }

  .header.scrolled {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(15px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(255, 1, 5, 0.2);
  }

  .logo {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--color-red);
    font-family: var(--font-syne);
  }

  .nav {
    display: flex;
    gap: 1rem;
  }

  .nav a {
    color: var(--color-red);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    padding: 0.65rem 1.5rem;
    border-radius: 50px;
  }

  .nav a.active {
    background: rgba(255, 255, 255, 0.85);
  }

  .nav a:hover {
    background: rgba(255, 255, 255, 1);
    transform: translateY(-2px);
  }

  .hero-text {
    position: absolute;
    right: 5%;
    top: 30%;
    max-width: 56vw;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  h1 {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 0.95;
    max-width: 100%;
  }

  .line-in {
    opacity: 0;
    transform: translateY(110%);
    animation: lineIn var(--dur-slow, 700ms) var(--ease-out, ease-out) forwards;
    animation-delay: 0.1s;
  }

  .line-in-delay-1 {
    animation-delay: 0.25s;
  }

  .line-in-delay-2 {
    animation-delay: 0.45s;
  }

  @keyframes lineIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hi {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--color-red);
    margin-bottom: 0.2rem;
    letter-spacing: -0.01em;
    font-family: var(--font-syne);
    white-space: nowrap;
  }

  .name {
    font-size: clamp(2.6rem, 7.5vw, 5.8rem);
    font-weight: 800;
    color: var(--color-dark-gray);
    letter-spacing: -0.02em;
    font-family: var(--font-syne);
    white-space: nowrap;
  }

  .tagline {
    margin: 2rem 0 0 0;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 400;
    background: var(--color-white);
    display: inline-block;
    padding: 0.8rem 2.5rem;
    border-radius: 50px;
    max-width: fit-content;
    font-family: var(--font-syne);
  }

  .tagline .red {
    color: var(--color-red);
    font-weight: 700;
  }

  .tagline .gray {
    color: var(--color-black);
    font-weight: 400;
  }

  .scroll-cue {
    position: absolute;
    bottom: 2.5rem;
    left: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: fadeIn 0.6s ease-out 1s forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  .scroll-cue-line {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.5);
    overflow: hidden;
    position: relative;
  }

  .scroll-cue-line::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-red);
    animation: scrollLine 1.8s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0% { top: -100%; }
    50% { top: 0%; }
    100% { top: 100%; }
  }

  .scroll-cue-text {
    font-size: 0.7rem;
    letter-spacing: 3px;
    color: rgba(255, 255, 255, 0.7);
    writing-mode: vertical-rl;
    font-family: var(--font-syne);
  }

  @media (prefers-reduced-motion: reduce) {
    .line-in {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .scroll-cue {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .scroll-cue {
      display: none;
    }

    .header {
      padding: 1.5rem 2rem;
      flex-direction: column;
      gap: 1.5rem;
    }

    .nav {
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav a {
      padding: 0.5rem 0.9rem;
      font-size: 0.7rem;
    }

    .hero-text {
      left: 50%;
      right: auto;
      top: 50%;
      max-width: 100%;
      transform: translate(-50%, -50%);
      padding: 0 2rem;
      width: 100%;
      align-items: center;
      text-align: center;
    }

    h1 {
      align-items: center;
    }

    .hi,
    .name {
      white-space: normal;
    }

    .tagline {
      padding: 0.6rem 1.5rem;
    }
  }
</style>
