---
import { getImage } from 'astro:assets';
import eceImg from '../assets/ECE worshop/Hero sec.png';
import gowaterzImg from '../assets/goWaterz/gowaterzHero.png';
import deliciousImg from '../assets/Delicious/poster design.png';
import jvImg from '../assets/Jv Springs/Hero sec.png';

const eceThumb = await getImage({ src: eceImg, width: 480, format: 'webp', quality: 75 });
const gowaterzThumb = await getImage({ src: gowaterzImg, width: 480, format: 'webp', quality: 75 });
const deliciousThumb = await getImage({ src: deliciousImg, width: 480, format: 'webp', quality: 75 });
const jvThumb = await getImage({ src: jvImg, width: 480, format: 'webp', quality: 75 });

const projects = [
  {
    title: "Tripzzie",
    category: "WEBSITE DESIGN",
    link: "#",
    preview: null
  },
  {
    title: "ECE Workshop",
    category: "LANDING PAGE",
    link: "/eceworkshop",
    preview: eceThumb.src
  },
  {
    title: "Go Waterz",
    category: "LOGO DESIGN",
    link: "/gowaterz",
    preview: gowaterzThumb.src
  },
  {
    title: "Delicious",
    category: "POSTER DESIGN",
    link: "/delicious",
    preview: deliciousThumb.src
  },
  {
    title: "JV Springs",
    category: "POSTER DESIGN",
    link: "/jvsprings",
    preview: jvThumb.src
  }
];
---

<section class="work" id="work">
  <div class="work-container">
    <div class="red-blob"></div>

    <div class="work-header reveal">
      <h2 class="work-title">
        <span class="white">SELECTED</span>
        <span class="red">WORKS</span>
      </h2>
      <p class="work-subtitle">Brand identity, web design & visual communication</p>
    </div>

    <div class="projects-list" data-stagger id="projects-list">
      {projects.map((project, index) => (
        <a
          href={project.link}
          class="project-item reveal"
          data-cursor-hover
          data-preview={project.preview ?? ''}
        >
          <div class="project-info">
            <span class="project-number">0{index + 1}</span>
            <div class="project-details">
              <h3 class="project-title">{project.title}</h3>
              <p class="project-category">{project.category}</p>
            </div>
          </div>
          <div class="project-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      ))}
      <div class="project-preview" id="project-preview">
        <img src="" alt="" id="project-preview-img" />
      </div>
    </div>

    <div class="cta-section reveal">
      <h3 class="cta-title">Let's work together</h3>
      <p class="cta-subtitle">Available for freelance projects</p>
      <a href="#contact" class="cta-button" data-cursor-hover>CONTACT</a>
    </div>
  </div>
</section>

<script>
  const list = document.getElementById('projects-list');
  const preview = document.getElementById('project-preview');
  const previewImg = document.getElementById('project-preview-img');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isFinePointer = window.matchMedia('(pointer: fine)').matches;

  if (list && preview && previewImg && isFinePointer && !reduceMotion) {
    const items = list.querySelectorAll('.project-item');

    items.forEach((item) => {
      const src = item.getAttribute('data-preview');

      item.addEventListener('mouseenter', () => {
        if (!src) return;
        previewImg.setAttribute('src', src);
        preview.classList.add('is-active');
      });

      item.addEventListener('mouseleave', () => {
        preview.classList.remove('is-active');
      });
    });

    list.addEventListener('mousemove', (e) => {
      const rect = list.getBoundingClientRect();
      preview.style.left = `${e.clientX - rect.left}px`;
      preview.style.top = `${e.clientY - rect.top}px`;
    });
  }
</script>

<style>
  .work {
    background-color: #1a1a1a;
    color: var(--color-white);
    padding: 6rem 3rem;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .work-container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .red-blob {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 1, 5, 0.3) 0%, rgba(255, 1, 5, 0) 70%);
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
  }

  .work-header {
    margin-bottom: 5rem;
  }

  .work-title {
    font-family: var(--font-syne);
    font-size: clamp(3.2rem, 9vw, 7rem);
    font-weight: 800;
    margin: 0;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .work-title .white {
    display: block;
    color: var(--color-white);
  }

  .work-title .red {
    display: block;
    color: var(--color-red);
  }

  .work-subtitle {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    font-weight: 400;
    color: #888;
    margin: 1rem 0 0 0;
    letter-spacing: 1px;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 8rem;
    position: relative;
  }

  .project-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2.5rem 0;
    border-bottom: 1px solid #2a2a2a;
    text-decoration: none;
    color: var(--color-white);
    transition: padding var(--dur-base, 0.3s) var(--ease-out, ease), border-color var(--dur-base, 0.3s) var(--ease-out, ease);
  }

  .project-item:hover {
    padding-left: 1.5rem;
    border-bottom-color: var(--color-red);
  }

  .project-item:hover .project-title {
    color: var(--color-red);
    transform: translateX(6px);
  }

  .project-item:hover .project-arrow {
    transform: translate(5px, -5px) rotate(45deg);
    color: var(--color-red);
    border-color: var(--color-red);
  }

  .project-preview {
    position: absolute;
    top: 0;
    left: 0;
    width: 280px;
    height: 200px;
    border-radius: 12px;
    overflow: hidden;
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0.85);
    opacity: 0;
    transition: opacity var(--dur-base, 0.3s) var(--ease-out, ease), transform var(--dur-base, 0.3s) var(--ease-out, ease);
    z-index: 5;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .project-preview.is-active {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .project-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-info {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .project-number {
    font-family: var(--font-syne);
    font-size: 1.1rem;
    font-weight: 400;
    color: #666;
  }

  .project-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-title {
    font-family: var(--font-syne);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 400;
    margin: 0;
    color: var(--color-white);
    display: inline-block;
    transition: color var(--dur-base, 0.3s) var(--ease-out, ease), transform var(--dur-base, 0.3s) var(--ease-out, ease);
  }

  .project-category {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 400;
    margin: 0;
    color: #888;
    letter-spacing: 1px;
  }

  .project-arrow {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 1px solid #3a3a3a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    transition: transform var(--dur-base, 0.3s) var(--ease-out, ease), color var(--dur-base, 0.3s) var(--ease-out, ease), border-color var(--dur-base, 0.3s) var(--ease-out, ease);
  }

  .cta-section {
    text-align: left;
    padding-top: 2rem;
  }

  .cta-title {
    font-family: var(--font-syne);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    margin: 0 0 0.5rem 0;
    color: var(--color-white);
  }

  .cta-subtitle {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    font-weight: 400;
    color: #888;
    margin: 0 0 2rem 0;
  }

  .cta-button {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 700;
    background-color: var(--color-white);
    color: var(--color-black);
    padding: 0.9rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    letter-spacing: 1px;
    display: inline-block;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background-color: var(--color-red);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .project-preview {
      display: none;
    }

    .work {
      padding: 4rem 2rem;
    }

    .work-title {
      font-size: clamp(1.8rem, 9vw, 3rem);
    }

    .work-header {
      margin-bottom: 3rem;
    }

    .project-info {
      gap: 1.5rem;
    }

    .project-number {
      font-size: 0.9rem;
    }

    .project-item {
      padding: 2rem 0;
    }

    .project-arrow {
      width: 40px;
      height: 40px;
    }

    .projects-list {
      margin-bottom: 5rem;
    }
  }
</style>
