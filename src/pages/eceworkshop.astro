---
import Layout from '../layouts/Layout.astro';
import heroSec from '../assets/ECE worshop/Hero sec.png';
import webflow from '../assets/ECE worshop/webflow.png';
import letsLearn from '../assets/ECE worshop/letslearn.png';
import modern from '../assets/ECE worshop/modern.png';
---

<Layout>
  <div class="project-page">
    <a href="/" class="back-button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      BACK
    </a>

    <div class="project-content">
      <div class="hero-section">
        <img src={heroSec.src} alt="Hero Background" class="hero-bg-image" />
        <div class="hero-content">
          <div class="spacer"></div>
          
          <div class="bottom-section">
            <p class="logo-label">LANDING PAGE</p>
            <h1 class="project-name">ECE Workshop</h1>
            <div class="project-details">
            <div class="detail-item">
              <p class="detail-label">YEAR</p>
              <p class="detail-value">2025</p>
            </div>

            <div class="detail-item">
              <p class="detail-label">PROJECT</p>
              <p class="detail-value">Educational Institute</p>
            </div>

            <div class="detail-item">
              <p class="detail-label">ROLE</p>
              <p class="detail-value">UI Designer</p>
            </div>

            <div class="detail-item">
              <p class="detail-label">CATEGORY</p>
              <p class="detail-value">Landing Page</p>
            </div>
            </div>
          </div>
        </div>
      </div>

      <div class="description-section">
        <h2 class="section-title">OVERVIEW</h2>
        
        <div class="overview-content">
          <h3 class="overview-heading">Domain: Electronics & Communication Engineering</h3>
          
          <div class="overview-item">
            <h4 class="overview-subtitle">Audience:</h4>
            <ul class="overview-list">
              <li>Undergraduate & postgraduate students</li>
              <li>Faculty members</li>
              <li>Academic coordinators</li>
            </ul>
          </div>

          <div class="overview-item">
            <h4 class="overview-subtitle">My Role:</h4>
            <p class="overview-text">UI Design, Visual System, Layout Structure, Typography & Color Decisions</p>
          </div>
        </div>

        <div class="challenge-section">
          <h3 class="section-subtitle">THE CHALLENGE</h3>
          <p class="description-text">
            How might we design a workshop website that feels formal and academic, while still being modern, readable, and engaging for students?
          </p>
        </div>

        <div class="objective-section">
          <h3 class="section-subtitle">THE OBJECTIVE</h3>
          <p class="description-text">
            The primary goal of this project was to design a static academic workshop website that:
          </p>
          <ul class="objective-list">
            <li>Communicates information clearly and quickly</li>
            <li>Feels trustworthy and institution-backed</li>
            <li>Supports both students and faculty audiences</li>
            <li>Maintains a conservative, academic visual tone</li>
            <li>Can scale for future workshops and departments</li>
          </ul>
          <p class="description-text">
            Rather than focusing on promotion, the design prioritizes legibility, hierarchy, and clarity.
          </p>
        </div>

        <div class="design-approach-section">
          <h3 class="section-subtitle">DESIGN APPROACH</h3>
          <p class="description-text">
            Before jumping into visuals, I defined a clear direction for the project. This design follows Version A – Academic / Institutional style, characterized by:
          </p>
          <ul class="objective-list">
            <li>Typography for authority</li>
            <li>Muted, minimal color palette</li>
            <li>Formal and neutral tone</li>
            <li>Clear content hierarchy</li>
            <li>Predictable navigation patterns</li>
          </ul>
          <p class="description-text">
            The intent was not to impress visually, but to build confidence and trust.
          </p>
        </div>

        <div class="flow-section">
          <h3 class="section-subtitle">PAGE FLOW & INFORMATION ARCHITECTURE</h3>
          <div class="flow-image-wrapper">
            <img src={webflow.src} alt="ECE Workshop Website User Flow & Information Architecture" class="flow-image" />
          </div>
        </div>

        <div class="visual-design-section">
          <h3 class="section-subtitle">VISUAL DESIGN SYSTEM</h3>
          <div class="visual-design-image-wrapper">
            <img src={letsLearn.src} alt="Visual Design System" class="visual-design-image" />
          </div>

          <div class="design-details">
            <div class="design-item">
              <h4 class="design-item-title">Typography</h4>
              <p class="design-item-text">
                Typography plays a key role in establishing academic credibility. This pairing bridges traditional authority with contemporary readability.
              </p>
            </div>

            <div class="design-item">
              <h4 class="design-item-title">Color Palette</h4>
              <p class="design-item-text">
                The color system is intentionally minimal: Maroon is widely used in academic and institutional branding, conveying seriousness and trust. Limiting the palette avoids visual distraction and maintains focus on content.
              </p>
            </div>
          </div>
        </div>

        <div class="key-design-section">
          <div class="key-design-image-wrapper">
            <img src={modern.src} alt="Key Design Decisions" class="key-design-image" />
          </div>

          <h3 class="section-subtitle">KEY DESIGN DECISIONS</h3>

          <div class="final-design-content">
            <h4 class="final-design-title">The Final design delivers:</h4>
            <ul class="final-design-list">
              <li>A clean, credible academic workshop website</li>
              <li>Clear communication of event details</li>
              <li>Strong visual hierarchy and readability</li>
              <li>A reusable structure for future academic events</li>
            </ul>
            <p class="final-design-text">
              The result is a website that feels official, professional, and student-friendly, aligning with the expectations of an academic institution.
            </p>

            <h4 class="design-principles-title">Design Principles:</h4>
            <ul class="design-principles-list">
              <li>Prioritized content hierarchy over decoration</li>
              <li>Used familiar academic layouts to reduce learning curve</li>
              <li>Avoided bright colors and playful elements</li>
              <li>Designed for clarity, not persuasion</li>
            </ul>
            <p class="design-evaluation-text">
              Every design choice was evaluated through the lens of "Does this build trust?"
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .project-page {
    min-height: 100vh;
    background-color: #000;
    color: #fff;
    margin: 0;
    padding: 0;
  }

  .back-button {
    position: fixed;
    top: 2rem;
    left: 2.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 1.5px;
    transition: all 0.3s ease;
    z-index: 9998;
    opacity: 0.9;
  }

  .back-button:hover {
    opacity: 1;
    color: #FF0000;
  }

  .back-button svg {
    width: 14px;
    height: 14px;
  }

  .project-content {
    padding-top: 0;
  }

  .hero-section {
    height: 100vh;
    display: flex;
    align-items: flex-end;
    position: relative;
    background-color: #000;
    overflow: hidden;
    margin: 0;
    padding: 0;
    top: 0;
    left: 0;
  }

  .hero-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    z-index: 0;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 70%, rgba(0,0,0,0.8) 90%, rgba(0,0,0,0.95) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    z-index: 2;
  }

  .spacer {
    flex: 1;
  }

  .bottom-section {
    padding: 3rem;
  }

  .logo-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }

  .project-name {
    font-size: 4rem;
    font-weight: 700;
    color: #FF0000;
    margin: 0 0 2rem 0;
    letter-spacing: 0.05em;
  }

  .project-details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1200px;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .detail-value {
    font-size: 1rem;
    color: #fff;
    margin: 0;
  }

  .description-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 6rem 3rem;
  }

  .section-title {
    font-size: 0.625rem;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 3rem;
    text-transform: uppercase;
    font-weight: 400;
  }

  .overview-content {
    margin-bottom: 5rem;
  }

  .overview-heading {
    font-size: 1.75rem;
    font-weight: 400;
    color: #fff;
    margin: 0 0 3rem 0;
    line-height: 1.5;
  }

  .overview-item {
    margin-bottom: 2.5rem;
  }

  .overview-subtitle {
    font-size: 1.125rem;
    font-weight: 400;
    color: #fff;
    margin: 0 0 0.75rem 0;
  }

  .overview-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .overview-list li {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
    font-weight: 300;
  }

  .overview-list li::before {
    content: '▪';
    position: absolute;
    left: 0;
    color: #fff;
    font-size: 0.875rem;
  }

  .overview-text {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-weight: 300;
  }

  .challenge-section,
  .objective-section {
    margin-bottom: 5rem;
  }

  .section-subtitle {
    font-size: 0.625rem;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 1.25rem 0;
    text-transform: uppercase;
    font-weight: 400;
  }

  .description-text {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .objective-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }

  .objective-list li {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.75rem;
    font-weight: 300;
  }

  .objective-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: #fff;
    font-size: 1rem;
  }

  .design-approach-section {
    margin-bottom: 5rem;
  }

  .flow-section {
    margin-bottom: 4rem;
  }

  .flow-image-wrapper {
    margin-top: 2rem;
  }

  .flow-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .visual-design-section {
    margin-bottom: 4rem;
  }

  .visual-design-image-wrapper {
    margin-top: 2rem;
    margin-bottom: 3rem;
  }

  .visual-design-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .design-details {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .design-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .design-item-title {
    font-size: 1rem;
    font-weight: 400;
    color: #fff;
    margin: 0;
  }

  .design-item-text {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-weight: 300;
  }

  .key-design-section {
    margin-bottom: 4rem;
  }

  .key-design-image-wrapper {
    margin-bottom: 1.5rem;
    margin-top: 1.5rem;
  }

  .key-design-image {
    width: 100%;
    margin-top: 1.5rem;
    display: block;
  }

  .final-design-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .final-design-title,
  .design-principles-title {
    font-size: 1rem;
    font-weight: 400;
    color: #fff;
    margin: 0;
  }

  .final-design-list,
  .design-principles-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0;
  }

  .final-design-list li,
  .design-principles-list li {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
    font-weight: 300;
  }

  .final-design-list li::before,
  .design-principles-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: #fff;
    font-size: 1rem;
  }

  .final-design-text,
  .design-evaluation-text {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .project-name {
      font-size: 2.5rem;
    }

    .project-details {
      grid-template-columns: repeat(2, 1fr);
    }

    .bottom-section {
      padding: 2rem;
    }

    .description-section {
      padding: 4rem 2rem;
    }

    .overview-heading {
      font-size: 1.25rem;
    }
  }
</style>
