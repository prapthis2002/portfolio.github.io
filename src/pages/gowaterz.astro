---
import Layout from '../layouts/Layout.astro';
import gowaterzHero from '../assets/goWaterz/gowaterzHero.png';
import gowaterz2 from '../assets/goWaterz/gowaterz 2.png';
import gowaterz3 from '../assets/goWaterz/goWaterz 3.png';
import gowaterz4 from '../assets/goWaterz/goWaterz 4.png';
import gowaterz5 from '../assets/goWaterz/goWaterz 5.png';
import gowaterz6 from '../assets/goWaterz/goWaterz 6.png';
---

<Layout>
  <div class="project-page">
    <a href="/" class="back-button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      BACK
    </a>

    <div class="project-content">
      <div class="hero-section" style={`background-image: url(${gowaterzHero.src});`}>
        <div class="hero-content">
          <div class="spacer"></div>
          
          <div class="bottom-section">
            <p class="logo-label">LOGO DESIGN</p>
            <h1 class="project-name">GOWATERZ</h1>
            <div class="project-details">
            <div class="detail-item">
              <p class="detail-label">YEAR</p>
              <p class="detail-value">2024</p>
            </div>

            <div class="detail-item">
              <p class="detail-label">PROJECT</p>
              <p class="detail-value">Gowaterz</p>
            </div>

            <div class="detail-item">
              <p class="detail-label">ROLE</p>
              <p class="detail-value">Logo Designer</p>
            </div>

            <div class="detail-item">
              <p class="detail-label">CATEGORY</p>
              <p class="detail-value">Logo design</p>
            </div>
            </div>
          </div>
        </div>
      </div>

      <div class="description-section">
        <h2 class="section-title">OVERVIEW</h2>
        <p class="description-text">
          The GO WATERZ logo was designed for a yacht rental, buying, and selling brand operating across India and select international waters. The identity balances luxury, trust, and fluid motion, reflecting both the marine environment and the premium nature of the services.
        </p>
        
        <div class="color-strategy">
          <h3 class="strategy-title">Color Strategy</h3>
          <p class="strategy-text">
            The brand uses a blue gradient palette, intentionally chosen to reflect different depths of water:
          </p>
          <ul class="strategy-list">
            <li>Deep blue conveys trust, authority, and professionalism — critical for high-value yacht transactions</li>
            <li>Lighter aqua tones express freshness, openness, and leisure</li>
            <li>The gradient transition mirrors the ocean's depth, reinforcing the brand's global scale and marine expertise</li>
          </ul>
          <p class="strategy-text">
            Blue also psychologically communicates calmness and confidence, aligning with stress-free luxury travel and premium maritime services.
          </p>
        </div>
      </div>

      <div class="mockups-section">
        <div class="mockup-row-1">
          <img src={gowaterz4.src} alt="Gowaterz phone mockup" class="mockup-image" />
        </div>
        
        <div class="mockup-row-2">
          <img src={gowaterz6.src} alt="Gowaterz app icon" class="mockup-image" />
          <img src={gowaterz3.src} alt="Gowaterz badge" class="mockup-image" />
          <img src={gowaterz2.src} alt="Gowaterz tag" class="mockup-image" />
        </div>
        
        <div class="mockup-row-3">
          <img src={gowaterz5.src} alt="Gowaterz wall signage" class="mockup-image" />
        </div>
      </div>

      <div class="color-palette">
        <div class="color-swatch" style="background-color: #1B67AF;">
          <span class="color-code">#1B67AF</span>
        </div>
        <div class="color-swatch" style="background-color: #196DAA;">
          <span class="color-code">#196DAA</span>
        </div>
        <div class="color-swatch" style="background-color: #30C7ED;">
          <span class="color-code">#30C7ED</span>
        </div>
        <div class="color-swatch white" style="background-color: #FEFEFE;">
          <span class="color-code black">#FEFEFE</span>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .project-page {
    background-color: #0a0a0a;
    min-height: 100vh;
    color: var(--color-white);
    position: relative;
    overflow-x: hidden;
  }

  .back-button {
    position: fixed;
    top: 2rem;
    left: 2.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-white);
    text-decoration: none;
    font-family: var(--font-syne);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 1.5px;
    transition: all 0.3s ease;
    z-index: 9998;
    opacity: 0.9;
  }

  .back-button:hover {
    opacity: 1;
    color: var(--color-red);
  }

  .back-button svg {
    width: 14px;
    height: 14px;
  }

  .project-content {
    position: relative;
    z-index: 1;
  }

  .hero-section {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background-color: #0a0b1a;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    padding: 0;
  }

  .hero-section::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to top, rgba(10, 10, 10, 1) 0%, rgba(10, 10, 10, 0.8) 30%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    z-index: 2;
  }

  .spacer {
    flex: 1;
  }

  .logo-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }

  .bottom-section {
    padding: 3rem;
  }

  .project-name {
    font-size: 4rem;
    font-weight: 700;
    color: #FF0000;
    margin: 0 0 2rem 0;
    letter-spacing: 0.05em;
  }

  .project-details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1200px;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .detail-value {
    font-size: 1rem;
    color: #fff;
    margin: 0;
  }

  .description-section {
    padding: 4rem 3rem 3rem 3rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-syne);
    font-size: 0.625rem;
    font-weight: 400;
    letter-spacing: 3px;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
  }

  .description-text {
    font-family: var(--font-syne);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-white);
    margin: 0 0 2.5rem 0;
  }

  .color-strategy {
    margin-top: 2rem;
  }

  .strategy-title {
    font-family: var(--font-syne);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 2.5px;
    color: rgba(150, 200, 220, 0.8);
    margin: 0 0 1.25rem 0;
    text-transform: uppercase;
  }

  .strategy-text {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 1.25rem 0;
  }

  .strategy-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.5rem 0;
  }

  .strategy-list li {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.8rem;
    padding-left: 1.2rem;
    position: relative;
  }

  .strategy-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: rgba(150, 200, 220, 0.8);
    font-size: 1rem;
  }

  .mockups-section {
    padding: 2rem 3rem;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mockup-row-1,
  .mockup-row-3 {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  .mockup-row-2 {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.25rem;
  }

  .mockup-row-1 .mockup-image,
  .mockup-row-3 .mockup-image {
    width: 100%;
    max-width: 900px;
  }

  .mockup-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .color-palette {
    padding: 1rem 0 3rem 0;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .color-swatch {
    width: 100%;
    height: 60px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .color-swatch.white {
    border: 1px solid #252525;
  }

  .color-code {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    color: var(--color-white);
  }

  .color-code.black {
    color: #0a0a0a;
  }

  @media (max-width: 1024px) {
    .project-details {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1rem;
    }

    .project-name {
      font-size: clamp(2.5rem, 10vw, 5.5rem);
    }
    
    .mockup-row-2 {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 1.5rem 1.25rem 2rem 1.25rem;
      min-height: 100vh;
    }

    .back-button {
      top: 1.25rem;
      left: 1.25rem;
      font-size: 0.65rem;
      gap: 0.4rem;
    }

    .back-button svg {
      width: 12px;
      height: 12px;
    }

    .project-details {
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem 0.75rem;
    }

    .project-name {
      font-size: clamp(2.25rem, 11vw, 4rem);
      line-height: 0.9;
    }

    .logo-label {
      font-size: 0.5rem;
      letter-spacing: 2.5px;
      margin-bottom: 0.5rem;
    }

    .detail-label {
      font-size: 0.55rem;
      letter-spacing: 1.5px;
    }

    .detail-value {
      font-size: 0.9rem;
    }

    .description-section {
      padding: 3rem 1.25rem 2rem 1.25rem;
    }

    .description-text {
      font-size: 0.875rem;
      line-height: 1.65;
    }

    .strategy-title {
      font-size: 0.65rem;
      letter-spacing: 2px;
    }

    .strategy-text,
    .strategy-list li {
      font-size: 0.8rem;
      line-height: 1.55;
    }

    .mockups-section {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .color-palette {
      max-width: 600px;
    }

    .mockup-row-1,
    .mockup-row-2,
    .mockup-row-3 {
      max-width: 600px;
    }

    .mockup-row-1 .mockup-image,
    .mockup-row-3 .mockup-image {
      max-width: 600px;
    }

    .mockup-row-2 {
      grid-template-columns: 1fr;
    }

    .bottom-section {
      gap: 1.25rem;
    }

    .color-swatch {
      height: 55px;
    }

    .color-code {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .hero-content {
      padding: 1.25rem 1rem 1.75rem 1rem;
    }

    .back-button {
      top: 1rem;
      left: 1rem;
      font-size: 0.6rem;
    }

    .project-name {
      font-size: clamp(1.85rem, 13vw, 3.25rem);
      line-height: 0.95;
    }
    
    .project-details {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .logo-label {
      font-size: 0.475rem;
      letter-spacing: 2px;
    }

    .detail-label {
      font-size: 0.5rem;
      margin-bottom: 0.4rem;
    }

    .detail-value {
      font-size: 0.85rem;
    }

    .bottom-section {
      gap: 1rem;
    }

    .description-section {
      padding: 2.5rem 1rem 1.5rem 1rem;
    }

    .description-text,
    .strategy-text,
    .strategy-list li {
      font-size: 0.8rem;
    }

    .strategy-title {
      font-size: 0.6rem;
      letter-spacing: 1.75px;
    }

    .mockups-section {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .color-palette {
      max-width: 500px;
    }

    .mockup-row-1,
    .mockup-row-2,
    .mockup-row-3 {
      max-width: 500px;
    }

    .mockup-row-1 .mockup-image,
    .mockup-row-3 .mockup-image {
      max-width: 500px;
    }

    .color-swatch {
      height: 50px;
    }

    .color-code {
      font-size: 0.8rem;
    }
  }
</style>
