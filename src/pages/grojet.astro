---
import { Image, getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import toteFlat from '../assets/Grojet/tote-flat.webp';
import toteMockup from '../assets/Grojet/tote-mockup.webp';
import festiveVishu from '../assets/Grojet/festive-vishu.webp';
import festiveRamNavami from '../assets/Grojet/festive-ramnavami.webp';
import festiveEid from '../assets/Grojet/festive-eid.webp';
import merchantNila from '../assets/Grojet/merchant-nila.webp';
import merchantCanara from '../assets/Grojet/merchant-canara.webp';
import merchantBhatnbhat from '../assets/Grojet/merchant-bhatnbhat.webp';
import tyCard from '../assets/Grojet/ty-card.webp';
import tyCard2 from '../assets/Grojet/ty-card-2.webp';
import tyCards from '../assets/Grojet/ty-cards.webp';

const optimizedHeroBg = await getImage({ src: festiveVishu, width: 1920, format: 'webp', quality: 75 });

const brandColors = [
  { hex: '#DFEC30', name: 'Lime Yellow', light: false },
  { hex: '#000000', name: 'Black', light: true },
  { hex: '#FFFFFF', name: 'White', light: false },
];

const categories = [
  {
    number: '01',
    key: 'festival',
    title: 'Festival Posters',
    description: 'Celebrating festivals with local flavor and festive vibes.',
    layout: 'row3',
    images: [
      { src: festiveRamNavami, alt: 'Happy Ram Navami festive poster' },
      { src: festiveEid, alt: 'Eid Mubarak festive poster' },
      { src: festiveVishu, alt: 'Happy Vishu festive poster' },
    ],
  },
  {
    number: '02',
    key: 'merchant',
    title: 'Merchant Stories',
    description: 'Highlighting local businesses we partner with.',
    layout: 'row3',
    images: [
      { src: merchantCanara, alt: 'Grojet x Canara Farms fresh milk campaign' },
      { src: merchantBhatnbhat, alt: "Grojet x Bhat 'n' Bhat pickle campaign" },
      { src: merchantNila, alt: 'Grojet x Nila coffee & brownie campaign' },
    ],
  },
  {
    number: '03',
    key: 'social',
    title: 'Social Media Posts',
    description: 'Campaign posts shared across Instagram and WhatsApp.',
    layout: 'social',
    images: [
      { src: festiveRamNavami, alt: 'Ram Navami Instagram post' },
      { src: festiveEid, alt: 'Eid Mubarak Instagram post' },
      { src: festiveVishu, alt: 'Vishu Instagram post' },
      { src: merchantCanara, alt: 'Canara Farms Instagram post' },
      { src: merchantBhatnbhat, alt: 'Bhat n Bhat Instagram post' },
      { src: merchantNila, alt: 'Nila Instagram post' },
    ],
  },
  {
    number: '04',
    key: 'thankyou',
    title: 'Thank You Card',
    description: 'Turning unboxing into a fun and interactive experience.',
    layout: 'tycard',
    images: [
      { src: tyCard, alt: 'Grojet thank-you card design' },
      { src: tyCard2, alt: 'Grojet thank-you card mockup' },
      { src: tyCards, alt: 'Grojet thank-you card collection' },
    ],
  },
  {
    number: '05',
    key: 'merchandise',
    title: 'Merchandise',
    description: 'Mangalore doodle tote bag design.',
    layout: 'row2',
    images: [
      { src: toteFlat, alt: 'Grojet tote bag flat design' },
      { src: toteMockup, alt: 'Grojet tote bag lifestyle mockup' },
    ],
  },
];

const filters = [
  { label: 'All', key: 'all' },
  ...categories.map((c) => ({ label: c.title, key: c.key })),
];
---

<Layout>
  <div class="project-page">
    <a href="/" class="back-button" data-cursor-hover>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      BACK
    </a>

    <div class="project-content">
      <section class="hero-section" style={`--hero-bg: url(${optimizedHeroBg.src});`}>
        <div class="hero-content">
          <div class="hero-logo-wrap reveal-scale">
            <img src="/grojet-logo.svg" alt="Grojet logo" class="hero-logo" />
          </div>

          <div class="spacer"></div>

          <div class="bottom-section">
            <p class="logo-label reveal">BRAND & MARKETING DESIGN</p>
            <h1 class="project-name reveal">GROJET</h1>
            <div class="project-details reveal" data-stagger>
              <div class="detail-item">
                <p class="detail-label">YEAR</p>
                <p class="detail-value">2025</p>
              </div>

              <div class="detail-item">
                <p class="detail-label">PROJECT</p>
                <p class="detail-value">Grojet</p>
              </div>

              <div class="detail-item">
                <p class="detail-label">ROLE</p>
                <p class="detail-value">Content Marketing Specialist</p>
              </div>

              <div class="detail-item">
                <p class="detail-label">CATEGORY</p>
                <p class="detail-value">Brand & Marketing Design</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="overview-section reveal">
        <h2 class="section-title">Project Overview</h2>
        <p class="overview-text">
          A series of marketing and brand assets designed for Grojet, Mangalore's trusted grocery & delivery app, to strengthen local connect, celebrate culture, and build a memorable brand experience beyond just delivery.
        </p>
      </section>

      <section class="brand-colors-section reveal">
        <h2 class="section-title">Brand Colours</h2>
        <div class="color-swatches">
          {brandColors.map((c) => (
            <div class="color-swatch" style={`background: ${c.hex};`}>
              <span class="color-hex" style={c.light ? 'color:#fff;' : 'color:#0a0a0a;'}>{c.hex}</span>
              <span class="color-name" style={c.light ? 'color:rgba(255,255,255,0.6);' : 'color:rgba(10,10,10,0.5);'}>{c.name}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="projects-section reveal">
        <p class="projects-label">PROJECTS</p>
        <h2 class="projects-heading">What I Designed for Grojet</h2>

        <div class="filter-row" id="filter-row" data-stagger>
          {filters.map((f, i) => (
            <button class="filter-pill" data-filter={f.key} aria-pressed={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        {categories.map((cat) => (
          <div class="category-block" data-category={cat.key}>
            <div class="category-header">
              <div class="category-heading-group">
                <span class="category-number">{cat.number}</span>
                <h3 class="category-title">{cat.title}</h3>
                <p class="category-desc">{cat.description}</p>
              </div>
              <span class="view-all">
                VIEW ALL
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
            <div class={`category-images ${cat.layout}`}>
              {cat.images.map((img) => (
                <div class="category-image">
                  <Image src={img.src} alt={img.alt} width={600} loading="lazy" data-cursor-hover />
                </div>
              ))}
            </div>
          </div>
        ))}
      </section>

      <a href="/gowaterz" class="next-project-btn reveal" data-cursor-hover>
        <span class="next-project-text">
          <span class="next-project-label">NEXT PROJECT</span>
          <span class="next-project-title">GOWATERZ</span>
        </span>
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <footer class="footer">
        <p>© 2026 Portfolio. All rights reserved.</p>
      </footer>
    </div>
  </div>
</Layout>

<script>
  const filterRow = document.getElementById('filter-row');
  const pills = filterRow?.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const blocks = document.querySelectorAll<HTMLElement>('.category-block');

  pills?.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.setAttribute('aria-pressed', 'false'));
      pill.setAttribute('aria-pressed', 'true');

      const filter = pill.dataset.filter;
      blocks.forEach((block) => {
        const show = filter === 'all' || block.dataset.category === filter;
        block.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .project-page {
    background-color: #0a0a0a;
    min-height: 100vh;
    color: var(--color-white);
    position: relative;
    overflow-x: hidden;
  }

  .back-button {
    position: fixed;
    top: 2rem;
    left: 2.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-white);
    text-decoration: none;
    font-family: var(--font-syne);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 1.5px;
    transition: color var(--dur-base, 0.3s) var(--ease-out, ease);
    z-index: 9998;
    opacity: 0.9;
  }

  .back-button:hover {
    opacity: 1;
    color: var(--color-red);
  }

  .back-button svg {
    width: 14px;
    height: 14px;
  }

  .project-content {
    position: relative;
    z-index: 1;
  }

  /* ── Hero ── */
  .hero-section {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background-color: #0a0a0a;
    position: relative;
    padding: 0;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: -5%;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(26px) brightness(0.32) saturate(0.75);
    z-index: 0;
  }

  .hero-section::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(to top, rgba(10, 10, 10, 1) 0%, rgba(10, 10, 10, 0.85) 30%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    z-index: 2;
  }

  .hero-logo-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    z-index: 2;
  }

  .hero-logo {
    display: block;
    width: clamp(200px, 26vw, 380px);
    height: auto;
    border-radius: 28px;
    filter: drop-shadow(0 30px 70px rgba(0, 0, 0, 0.55));
  }

  .spacer {
    flex: 1;
  }

  .bottom-section {
    position: relative;
    z-index: 2;
    padding: 3rem;
  }

  .logo-label {
    font-family: var(--font-syne);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }

  .project-name {
    font-family: var(--font-syne);
    font-size: clamp(2.8rem, 8vw, 6rem);
    font-weight: 800;
    color: var(--color-red);
    margin: 0 0 2rem 0;
    letter-spacing: -0.02em;
  }

  .project-details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1200px;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-label {
    font-family: var(--font-syne);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .detail-value {
    font-family: var(--font-syne);
    font-size: 1rem;
    color: var(--color-white);
    margin: 0;
  }

  /* ── Overview ── */
  .overview-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 3.5rem 3rem;
  }

  .section-title {
    font-family: var(--font-syne);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-red);
    margin: 0 0 1.5rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-red);
    display: inline-block;
  }

  .overview-text {
    font-family: var(--font-syne);
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    max-width: 680px;
  }

  /* ── Brand Colours ── */
  .brand-colors-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 3rem 3.5rem;
  }

  .color-swatches {
    display: flex;
    gap: 1rem;
  }

  .color-swatch {
    flex: 1;
    height: 110px;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 1rem 1.1rem;
    border: 1px solid #2a2a2a;
    transition: transform var(--dur-base, 0.3s) var(--ease-out, ease);
  }

  .color-swatch:hover {
    transform: translateY(-4px);
  }

  .color-hex {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    display: block;
  }

  .color-name {
    font-family: var(--font-syne);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    display: block;
    margin-top: 0.25rem;
  }

  /* ── Projects ── */
  .projects-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 3rem 4rem;
  }

  .projects-label {
    font-family: var(--font-syne);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 0.75rem 0;
  }

  .projects-heading {
    font-family: var(--font-syne);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 1rem 0;
    padding-bottom: 1rem;
    border-bottom: 3px solid var(--color-red);
    display: inline-block;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 2rem 0 3.5rem;
  }

  .filter-pill {
    font-family: var(--font-syne);
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    background-color: #1a1a1a;
    border: 1px solid #2a2a2a;
    padding: 0.55rem 1.25rem;
    border-radius: 50px;
    cursor: pointer;
    transition: background-color var(--dur-base, 0.3s) var(--ease-out, ease), color var(--dur-base, 0.3s) var(--ease-out, ease);
  }

  .filter-pill[aria-pressed="true"] {
    background-color: var(--color-red);
    color: var(--color-white);
    border-color: var(--color-red);
  }

  .category-block {
    padding: 2.5rem 0;
    border-bottom: 1px solid #2a2a2a;
  }

  .category-block:last-child {
    border-bottom: none;
  }

  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .category-number {
    font-family: var(--font-syne);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-red);
    display: block;
    margin-bottom: 0.4rem;
  }

  .category-title {
    font-family: var(--font-syne);
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    font-weight: 800;
    color: var(--color-red);
    letter-spacing: 0.02em;
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
  }

  .category-desc {
    font-family: var(--font-syne);
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    max-width: 420px;
  }

  .view-all {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-syne);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-red);
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.3rem;
  }

  /* ── Image grids ── */
  .category-images {
    display: grid;
    gap: 1rem;
  }

  /* 3-col tall: festival / merchant */
  .category-images.row3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .category-images.row3 .category-image img {
    aspect-ratio: 9 / 16;
  }

  /* 2-col: merchandise */
  .category-images.row2 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 700px;
  }

  .category-images.row2 .category-image img {
    aspect-ratio: 4 / 5;
  }

  /* 3×2 Instagram-style grid: social media posts */
  .category-images.social {
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }

  .category-images.social .category-image {
    border-radius: 4px;
    border: none;
  }

  .category-images.social .category-image img {
    aspect-ratio: 1 / 1;
  }

  /* Thank You Card: first 2 landscape, 3rd full-width portrait */
  .category-images.tycard {
    grid-template-columns: 1fr 1fr;
  }

  .category-images.tycard .category-image:nth-child(-n+2) img {
    aspect-ratio: 3 / 2;
  }

  .category-images.tycard .category-image:nth-child(3) {
    grid-column: span 2;
    max-width: 500px;
    justify-self: center;
    width: 100%;
  }

  .category-images.tycard .category-image:nth-child(3) img {
    aspect-ratio: 4 / 5;
  }

  /* shared card styles */
  .category-image {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #2a2a2a;
  }

  .category-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-base, 0.3s) var(--ease-out, ease);
  }

  .category-image:hover img {
    transform: scale(1.04);
  }

  /* ── Next project ── */
  .next-project-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: calc(100% - 6rem);
    max-width: 1200px;
    margin: 2rem auto 0;
    background-color: var(--color-red);
    border-radius: 20px;
    padding: 2rem 2.5rem;
    text-decoration: none;
    transition: transform var(--dur-base, 0.3s) var(--ease-out, ease);
  }

  .next-project-btn:hover {
    transform: translateY(-2px);
  }

  .next-project-text {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .next-project-label {
    font-family: var(--font-syne);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: rgba(255, 255, 255, 0.7);
  }

  .next-project-title {
    font-family: var(--font-syne);
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-white);
    letter-spacing: -0.02em;
  }

  .next-project-btn svg {
    color: var(--color-white);
    flex-shrink: 0;
  }

  .footer {
    padding: 3rem 3rem 2rem;
    text-align: center;
  }

  .footer p {
    font-family: var(--font-syne);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .back-button {
      top: 1.25rem;
      left: 1.25rem;
      font-size: 0.65rem;
      gap: 0.4rem;
    }

    .back-button svg {
      width: 12px;
      height: 12px;
    }

    .hero-content {
      min-height: 100vh;
    }

    .hero-logo {
      width: clamp(140px, 42vw, 220px);
    }

    .bottom-section {
      padding: 1.5rem 1.25rem 2rem 1.25rem;
    }

    .project-details {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem 0.75rem;
    }

    .project-name {
      font-size: clamp(1.7rem, 9vw, 3.2rem);
      line-height: 0.9;
    }

    .logo-label {
      font-size: 0.5rem;
      letter-spacing: 2.5px;
      margin-bottom: 0.5rem;
    }

    .overview-section {
      padding: 2.5rem 1.25rem;
    }

    .brand-colors-section {
      padding: 0 1.25rem 2.5rem;
    }

    .color-swatches {
      gap: 0.6rem;
    }

    .color-swatch {
      height: 90px;
      padding: 0.75rem 0.85rem;
    }

    .color-hex {
      font-size: 0.75rem;
    }

    .projects-section {
      padding: 1rem 1.25rem 3rem;
    }

    .category-header {
      flex-direction: column;
      gap: 0.5rem;
    }

    .category-images.row3,
    .category-images.social {
      grid-template-columns: 1fr;
    }

    .category-images.social {
      gap: 4px;
    }

    .category-images.row2 {
      grid-template-columns: 1fr;
    }

    .category-images.tycard {
      grid-template-columns: 1fr;
    }

    .category-images.tycard .category-image:nth-child(3) {
      grid-column: span 1;
      max-width: 100%;
    }

    .next-project-btn {
      width: calc(100% - 2.5rem);
      margin: 1.5rem 1.25rem 0;
      padding: 1.5rem 1.5rem;
    }

    .footer {
      padding: 2.5rem 1.25rem;
    }
  }
</style>
